# ====================================================
# TAX AI - Environment Variables
# Sao chép file này thành .env và điền giá trị thực
# ====================================================

# ---- TELEGRAM BOT ----
# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ---- ZALO OA ----
# Lấy từ https://developers.zalo.me/ → Ứng dụng của bạn → Zalo OA
ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token_here
ZALO_APP_SECRET=your_zalo_app_secret_here
ZALO_WEBHOOK_PORT=5000

# ---- CLAUDE API (NLP - tuỳ chọn) ----
# Lấy từ https://console.anthropic.com/
# Nếu không điền, bot vẫn hoạt động với rule-based NLP
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001
